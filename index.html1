```
<!-- SCHRITT 1: BASIS -->
<div class="sec" style="margin-top:4px">1. Bezeichnung &amp; Modus</div>
<div class="card">
  <div class="fg"><label>Name (Raum / Flaeche)</label>
    <input id="fNm" type="text" placeholder="z.B. Wohnzimmer, Fassade Nord" autocomplete="off">
  </div>
  <div class="tabs">
    <button class="tab on" data-mode="gesamt">&#9635; Raum</button>
    <button class="tab" data-mode="wand">&#9707; Wand/Wand</button>
    <button class="tab" data-mode="fassade">&#9968; Fassade</button>
  </div>
  <!-- VOB-Regelwahl -->
  <div class="fg">
    <label>VOB-Regelwerk</label>
    <select id="fVob">
      <option value="18363">DIN 18363 &ndash; Malerarbeiten (&le;2,5 m&sup2; kein Abzug)</option>
      <option value="18345">DIN 18345 &ndash; WDVS / Fassade (&le;1,0 m&sup2; kein Abzug)</option>
      <option value="18350">DIN 18350 &ndash; Putz &amp; Stuck (&le;0,1 m&sup2; kein Abzug)</option>
    </select>
  </div>
</div>

<!-- SCHRITT 2A: RAUM GESAMT -->
<div id="modeGesamt">
  <div class="sec">2. Raumabmessungen</div>
  <div class="card">
    <div class="row3">
      <div class="fg"><label id="lL">Laenge (m)</label>
        <input id="fL" type="number" min="0" step="any" placeholder="0"></div>
      <div class="fg"><label id="lB">Breite (m)</label>
        <input id="fB" type="number" min="0" step="any" placeholder="0"></div>
      <div class="fg"><label id="lH">Hoehe (m)</label>
        <input id="fH" type="number" min="0" step="any" placeholder="0"></div>
    </div>
    <div id="vorschau" class="ibox" style="display:none">
      Wand: <strong id="pvW">0</strong> &bull;
      Decke: <strong id="pvD">0</strong> &bull;
      Boden: <strong id="pvB">0</strong> m&sup2;
    </div>
  </div>
  <!-- Zusatzflaechen -->
  <div class="sec">Zusatzflaechen (Nischen / Laibungen)</div>
  <div id="zfListe"></div>
  <div style="margin-bottom:10px">
    <input id="zfNm" type="text" placeholder="Bezeichnung (optional)" style="width:100%;background:var(--s2);color:var(--txt);border:1.5px solid var(--bdr);border-radius:var(--rs);font-size:16px;padding:12px 14px;outline:none;margin-bottom:8px">
    <div style="display:grid;grid-template-columns:1fr auto 1fr auto;gap:8px;align-items:center">
      <input id="zfL" type="number" placeholder="Laenge" min="0" step="any" style="background:var(--s2);color:var(--txt);border:1.5px solid var(--bdr);border-radius:var(--rs);font-size:18px;padding:14px 12px;outline:none;text-align:center;width:100%">
      <span style="color:var(--mut);font-size:20px;font-weight:700;text-align:center">x</span>
      <input id="zfH" type="number" placeholder="Hoehe" min="0" step="any" style="background:var(--s2);color:var(--txt);border:1.5px solid var(--bdr);border-radius:var(--rs);font-size:18px;padding:14px 12px;outline:none;text-align:center;width:100%">
      <button class="btn btn-o" id="btnZF" style="padding:0;width:52px;height:52px;font-size:26px;border-radius:var(--rs);flex-shrink:0">+</button>
    </div>
  </div>
  <div id="zfSum" class="ibox" style="display:none">Zusatz: <strong id="zfSumV">0</strong> m&sup2;</div>
  <!-- Dachschraege -->
  <div class="div"></div>
  <div class="tgl-hd" id="schTgl">
    <span class="tgl-arr" id="schArr">&#9654;</span>
    <span style="font-size:13px;font-weight:600;color:var(--mut)">Dachschraege / Giebelwand</span>
  </div>
  <div class="tgl-body" id="schBody">
    <div class="wbox">Trapez: Breite &times; (H-links + H-rechts) / 2</div>
    <div class="row3">
      <div class="fg"><label id="lSB">Breite (m)</label><input id="sBr" type="number" min="0" step="any" placeholder="0"></div>
      <div class="fg"><label id="lSL">H links (m)</label><input id="sHL" type="number" min="0" step="any" placeholder="0"></div>
      <div class="fg"><label id="lSR">H rechts (m)</label><input id="sHR" type="number" min="0" step="any" placeholder="0"></div>
    </div>
    <div id="schVors" class="ibox" style="display:none">Giebelfl.: <strong id="schM2">0</strong> m&sup2; (addiert)</div>
  </div>
</div>

<!-- SCHRITT 2B: WAND FUER WAND -->
<div id="modeWand" style="display:none">
  <div class="sec">2. Waende</div>
  <div id="wandListe"></div>
  <div style="margin-bottom:10px">
    <input id="wNm" type="text" placeholder="Wandname (z.B. Nord, Sued)" style="width:100%;background:var(--s2);color:var(--txt);border:1.5px solid var(--bdr);border-radius:var(--rs);font-size:16px;padding:12px 14px;outline:none;margin-bottom:8px">
    <div style="display:grid;grid-template-columns:1fr 1fr auto;gap:8px;align-items:center">
      <input id="wL" type="number" placeholder="Laenge" min="0" step="any" style="background:var(--s2);color:var(--txt);border:1.5px solid var(--bdr);border-radius:var(--rs);font-size:18px;padding:14px 12px;outline:none;text-align:center;width:100%">
      <input id="wH" type="number" placeholder="Hoehe" min="0" step="any" style="background:var(--s2);color:var(--txt);border:1.5px solid var(--bdr);border-radius:var(--rs);font-size:18px;padding:14px 12px;outline:none;text-align:center;width:100%">
      <button class="btn btn-p" id="btnAddWand" style="padding:0;width:52px;height:52px;font-size:26px;border-radius:var(--rs);flex-shrink:0">+</button>
    </div>
  </div>
  <div class="fg">
    <label id="lDecke" style="display:block;font-size:10px;color:var(--mut);font-weight:700;text-transform:uppercase;letter-spacing:.4px;margin-bottom:8px">Decke berechnen (optional)</label>
    <div style="display:grid;grid-template-columns:1fr auto 1fr;gap:8px;align-items:center;margin-bottom:8px">
      <input id="deckL" type="number" min="0" step="any" placeholder="Laenge"
        style="background:var(--s2);color:var(--txt);border:1.5px solid var(--bdr);border-radius:var(--rs);font-size:18px;padding:13px 10px;outline:none;text-align:center;width:100%;-webkit-appearance:none">
      <span style="color:var(--mut);font-size:20px;font-weight:700;flex-shrink:0">x</span>
      <input id="deckB" type="number" min="0" step="any" placeholder="Breite"
        style="background:var(--s2);color:var(--txt);border:1.5px solid var(--bdr);border-radius:var(--rs);font-size:18px;padding:13px 10px;outline:none;text-align:center;width:100%;-webkit-appearance:none">
    </div>
    <div style="display:flex;align-items:center;gap:8px">
      <span style="color:var(--mut);font-size:12px;white-space:nowrap">= m&sup2;:</span>
      <input id="fDecke" type="number" min="0" step="any" placeholder="oder direkt m² eingeben"
        style="flex:1;background:var(--s2);color:var(--acc);border:1.5px solid var(--acc);border-radius:var(--rs);font-size:16px;font-weight:700;padding:10px 12px;outline:none;-webkit-appearance:none">
    </div>
  </div>
</div>

<!-- SCHRITT 2C: FASSADE -->
<div id="modeFassade" style="display:none">
  <div class="sec">2. Fassadenflaechen</div>
  <div id="fasSeiten"></div>
  <button class="btn btn-o btn-full btn-sm" id="btnAddSeite" style="margin-bottom:10px">+ Fassadenseite hinzufuegen</button>
  <!-- Sockelzone -->
  <div class="div"></div>
  <div class="tgl-hd" id="sockelTgl">
